rules_version = '2';

// =====================================================================
// КЕРБЕН B2B Market — Firestore Security Rules (МАКСИМАЛЬНАЯ ЗАЩИТА)
//
// Что закрывают эти правила:
//   • READ на customers/orders/chatMessages/chatClients — только для
//     залогиненных (Firebase Auth, в т.ч. анонимный). Внешние скрипты,
//     curl, боты без JS — отрезаны. С App Check + reCAPTCHA — закрыто
//     даже от автоматических браузеров.
//   • UPDATE/DELETE на customers — ТОЛЬКО владельцу документа
//     (request.auth.uid совпадает с customers.firebaseUid) или админу.
//     Хакер не может изменить чужой профиль, даже зная его id.
//   • UPDATE на orders — клиент может только ОТМЕНИТЬ свой заказ
//     (status='cancelled'). Изменить total/items/phone — нельзя.
//     Админ может всё.
//   • UPDATE на chatMessages — клиент может только пометить как
//     прочитанное (поле `read`). Текст и отправителя менять нельзя.
//   • DELETE везде — только админ.
//   • Пароли клиентов — хранятся ТОЛЬКО как PBKDF2-passwordHash.
//     Поле `password` (plaintext) запрещено: правила режут любые
//     попытки записать его (старые поля нужно вычистить из БД).
//   • Финансы (`expenses`) — только админ читает и пишет.
//   • notificationQueue — защищено от спама и подмены типа.
//   • Любая неизвестная коллекция — закрыта наглухо.
//
// =====================================================================
// ИНСТРУКЦИЯ ПО ДЕПЛОЮ (важно соблюдать порядок!):
//   1) Firebase Console → Authentication → Sign-in method:
//        • Anonymous → Enable
//        • Email/Password → Enable
//   2) Authentication → Users → Add user:
//        email: admin@kerben.local
//        password: тот же, что админ использует на сайте
//   3) ЗАЛИВАЕМ КОД на хостинг:
//        - js/auth.js
//        - js/customer-auth.js
//        - js/firebase-config.js
//        - js/chat.js
//        - js/order-tracking.js
//        - js/order-submit.js
//        - chat.html
//   4) Подождать 1-2 часа: чтобы у клиентов прогрузился новый код,
//      они зашли в свой профиль (миграция password → passwordHash идёт
//      при первом входе) и Firebase Auth закешировал анонимные uid.
//   5) ТОЛЬКО ПОТОМ задеплоить эти правила (Console → Firestore → Rules).
//      Если что-то пошло не так — откатить на резервную копию.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    //                        ХЕЛПЕРЫ
    // =========================================================

    // Админ через Firebase Auth (email-логин).
    function isAdminUser() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email == 'admin@kerben.local';
    }

    // Любой залогиненный (включая анонимных) или админ.
    function isAuthed() {
      return request.auth != null;
    }

    function isAdminPhone(p) {
      return p == '0559009860'
          || p == '+996559009860'
          || p == '996559009860'
          || p == '559009860';
    }

    // Никто, кроме админ-телефона, не может выставить isAdmin: true
    function notElevatingToAdmin() {
      return !('isAdmin' in request.resource.data)
          || request.resource.data.isAdmin != true
          || isAdminPhone(request.resource.data.phone);
    }

    // Timestamp в разумных пределах (±сутки от серверного времени)
    function reasonableTimestamp() {
      return !('timestamp' in request.resource.data)
          || (
              request.resource.data.timestamp is number
              && request.resource.data.timestamp >= request.time.toMillis() - 86400000
              && request.resource.data.timestamp <= request.time.toMillis() + 86400000
            );
    }

    // Заблокирован ли телефон (по документу blockedClients/{phone}).
    function isPhoneBlocked(phone) {
      return phone is string
          && phone.size() > 0
          && exists(/databases/$(database)/documents/blockedClients/$(phone));
    }

    // Защита от документов-монстров: не больше 200 полей в одном документе.
    function reasonableDocSize() {
      return request.resource.data.size() <= 200;
    }

    // Если поле есть — это строка не длиннее maxLen.
    function strOk(field, maxLen) {
      return !(field in request.resource.data)
          || (request.resource.data[field] is string
              && request.resource.data[field].size() <= maxLen);
    }

    // Если поле есть — это число в диапазоне [min..max].
    function numOk(field, minVal, maxVal) {
      return !(field in request.resource.data)
          || (request.resource.data[field] is number
              && request.resource.data[field] >= minVal
              && request.resource.data[field] <= maxVal);
    }

    // Поле НЕ изменяется при update (anti-tampering).
    // Используется чтобы запретить менять phone, isAdmin, passwordHash и т.п.
    function fieldUnchanged(field) {
      return !(field in request.resource.data) && !(field in resource.data)
          || ((field in request.resource.data) && (field in resource.data)
              && request.resource.data[field] == resource.data[field]);
    }

    // Plaintext-пароль (`password`) запрещён в БД — теперь только passwordHash.
    // НО: у старых клиентов в БД уже может лежать password от прошлых версий.
    // Чтобы не сломать им edit-profile/обновление статистики, разрешаем
    // legacy-значение оставаться в документе. Запрет действует на:
    //   1) CREATE: ни один новый документ не может содержать password.
    //   2) UPDATE: нельзя ДОБАВИТЬ password или ИЗМЕНИТЬ его. Удалить
    //      (FieldValue.delete) — можно (это и есть путь миграции).
    function noPlaintextPasswordAdded() {
      return !('password' in request.resource.data)
          || (resource != null
              && 'password' in resource.data
              && request.resource.data.password == resource.data.password);
    }

    // =========================================================
    //                       PRODUCTS
    // =========================================================
    // READ открыт всем — каталог должен открываться без логина.
    // DELETE — ТОЛЬКО админ.
    match /products/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('name', 500)
        && strOk('description', 5000)
        && strOk('category', 200)
        && strOk('subcategory', 200)
        && strOk('imageUrl', 2000)
        && strOk('image', 2000)
        && numOk('price', 0, 100000000)
        && numOk('quantity', -1000000, 10000000)
        && numOk('cost', 0, 100000000)
        && numOk('priceWholesale', 0, 100000000);
      allow delete: if isAdminUser();
    }

    // =========================================================
    //                  SELLERS / SELLER_CATEGORIES
    // =========================================================
    match /sellers/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('name', 200)
        && strOk('phone', 30)
        && strOk('description', 2000);
      allow delete: if isAdminUser();
    }

    match /seller_categories/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('name', 200)
        && strOk('description', 2000);
      allow delete: if isAdminUser();
    }

    // =========================================================
    //                       SETTINGS
    // =========================================================
    match /settings/{id} {
      allow read: if true;
      allow write: if reasonableDocSize();
    }

    // =========================================================
    //                    WAREHOUSES (нужны клиенту)
    // =========================================================
    match /warehouses/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('name', 200)
        && strOk('description', 2000);
      allow delete: if isAdminUser();
    }

    // =========================================================
    //                  AGENTS / CLIENT-AGENTS
    // =========================================================
    match /agents/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('name', 200)
        && strOk('phone', 30)
        && strOk('email', 200);
      allow delete: if isAdminUser();
    }

    match /clientAgents/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('phone', 30)
        && strOk('agentId', 200);
      allow delete: if isAdminUser();
    }

    // =========================================================
    //                     ФИНАНСЫ (расходы)
    // =========================================================
    // Только админ, ничего не открыто.
    match /expenses/{id} {
      allow read: if isAdminUser();
      allow create, update: if isAdminUser()
        && reasonableDocSize()
        && strOk('description', 2000)
        && strOk('category', 200)
        && numOk('amount', -1000000000, 1000000000)
        && reasonableTimestamp();
      allow delete: if isAdminUser();
    }

    // agentExpenses — расходы агентов. Их вносит сам агент через
    // agent-profit.html. У агентов нет отдельного auth — оставляем
    // открытым на запись (с валидацией) и удаление.
    match /agentExpenses/{id} {
      allow read: if true;
      allow create, update: if
        reasonableDocSize()
        && strOk('description', 2000)
        && strOk('agentId', 200)
        && numOk('amount', -1000000000, 1000000000)
        && reasonableTimestamp();
      allow delete: if true;
    }

    // =========================================================
    //                          ORDERS
    // =========================================================
    // READ — только залогиненный (анонимный auth тоже сойдёт).
    //        Это закрывает «выгрузку всей базы заказов» через curl/боты.
    // CREATE — анонимные клиенты могут создавать (с валидацией).
    // UPDATE — админ всё, клиент ТОЛЬКО отмена своего заказа
    //          (статус из 'pending'/'Новый' → 'cancelled'/'Отменён',
    //          остальные поля не меняются). Клиент НЕ может поменять
    //          сумму, товары, телефон или статус «Доставлен».
    // DELETE — только админ.
    match /orders/{orderId} {
      allow read: if isAuthed();
      allow delete: if isAdminUser();

      allow update: if reasonableDocSize() && (
        // === АДМИН — может всё (с разумным лимитом размера) ===
        isAdminUser()
        ||
        // === КЛИЕНТ — может ТОЛЬКО отменить или мягко отредактировать ===
        // 1) Сумма, товары, телефон, имя — НЕ меняются
        // 2) Дата создания — НЕ меняется
        // 3) Если меняется status — только в 'cancelled' / 'Отменён'
        //    из текущего pending/Новый/В обработке (не из «Доставлен»).
        (
          fieldUnchanged('total')
          && fieldUnchanged('items')
          && fieldUnchanged('phone')
          && fieldUnchanged('name')
          && fieldUnchanged('createdAt')
          && fieldUnchanged('timestamp')
          && fieldUnchanged('partner')
          && fieldUnchanged('referredBy')
          && fieldUnchanged('warehouseDeductions')
          && fieldUnchanged('stockDeducted')
          && (
            !('status' in request.resource.data)
            || request.resource.data.status == resource.data.status
            || request.resource.data.status == 'cancelled'
            || request.resource.data.status == 'Отменён'
          )
          // Нельзя отменить уже доставленный заказ
          && resource.data.status != 'Доставлен'
          && resource.data.status != 'Выполнен'
          && resource.data.status != 'delivered'
          && resource.data.status != 'completed'
        )
      );

      allow create: if
        reasonableDocSize()
        && request.resource.data.keys().hasAll(['name', 'phone', 'items', 'total'])

        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 200

        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.total <= 100000000

        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() <= 30
        && strOk('address', 1000)

        && reasonableTimestamp()
        && (
          !('status' in request.resource.data)
          || request.resource.data.status == 'pending'
        )
        && !isPhoneBlocked(request.resource.data.phone);
    }

    // =========================================================
    //                       CUSTOMERS
    // =========================================================
    // READ — только залогиненный (анонимный или админ). Это закрывает
    //        выгрузку всей клиентской базы конкурентам через консоль.
    // CREATE — открыт (нужно для регистрации новых клиентов).
    //          Запрещён plaintext password — только passwordHash.
    // UPDATE — админ всё, иначе ТОЛЬКО владелец документа
    //          (request.auth.uid совпадает с firebaseUid). Раньше любой
    //          мог изменить чужой профиль, зная id документа.
    //          Поля phone, isAdmin, firebaseUid, createdAt — НЕ меняются.
    //          ordersCount/totalSpent — может расти (через increment) или
    //          оставаться прежним, но не уменьшаться вручную.
    // DELETE — только админ.
    match /customers/{customerId} {
      allow read: if isAuthed();
      allow delete: if isAdminUser();

      allow create: if
        reasonableDocSize()
        && noPlaintextPasswordAdded()
        && notElevatingToAdmin()
        && strOk('name', 200)
        && strOk('phone', 30)
        && strOk('email', 200)
        && strOk('address', 1000)
        && strOk('passwordHash', 500)
        && strOk('firebaseUid', 200)
        && (
          !('phone' in request.resource.data)
          || !isPhoneBlocked(request.resource.data.phone)
        );

      allow update: if reasonableDocSize() && noPlaintextPasswordAdded() && (
        // === АДМИН — может всё ===
        isAdminUser()
        ||
        // === ВЛАДЕЛЕЦ ДОКУМЕНТА (uid совпадает) — может править свой профиль ===
        // Не может менять: phone, isAdmin, firebaseUid, createdAt
        // Может менять: name, address, email, passwordHash, ordersCount, totalSpent, lastOrderAt
        (
          isAuthed()
          && resource.data.firebaseUid is string
          && resource.data.firebaseUid == request.auth.uid
          && fieldUnchanged('phone')
          && fieldUnchanged('isAdmin')
          && fieldUnchanged('firebaseUid')
          && fieldUnchanged('createdAt')
          && strOk('name', 200)
          && strOk('email', 200)
          && strOk('address', 1000)
          && strOk('passwordHash', 500)
        )
        ||
        // === МИГРАЦИЯ: разрешаем ОДНОКРАТНО привязать firebaseUid
        // к документу, у которого его ещё нет. Это нужно при первом
        // входе старых клиентов после обновления сайта.
        // Условие: документ ещё не привязан, и мы не меняем
        // ничего, кроме firebaseUid и/или passwordHash.
        (
          isAuthed()
          && (!('firebaseUid' in resource.data) || resource.data.firebaseUid == null
              || resource.data.firebaseUid == '')
          && fieldUnchanged('phone')
          && fieldUnchanged('isAdmin')
          && fieldUnchanged('createdAt')
          && fieldUnchanged('name')
          && fieldUnchanged('address')
          && fieldUnchanged('email')
          && request.resource.data.firebaseUid == request.auth.uid
        )
      );
    }

    // =========================================================
    //                    BLOCKED CLIENTS
    // =========================================================
    // Только админ может блокировать/разблокировать клиентов.
    match /blockedClients/{blockedId} {
      allow read: if true;
      allow create, update: if isAdminUser()
        && !isAdminPhone(blockedId);
      allow delete: if isAdminUser();
    }

    // =========================================================
    //                       PUSH-ТОКЕНЫ
    // =========================================================
    // pushTokens — клиент пишет свой токен (валидация ниже).
    // READ закрыт — клиенту читать чужие токены незачем.
    match /pushTokens/{id} {
      allow read: if false;
      allow create, update: if
        reasonableDocSize()
        && strOk('token', 500)
        && strOk('clientId', 200)
        && strOk('role', 50);
      allow delete: if true;
    }

    // adminPushTokens — только серверная Cloud Function.
    match /adminPushTokens/{id} {
      allow read, write: if false;
    }

    // =========================================================
    //                    NOTIFICATION QUEUE
    // =========================================================
    // Защита от спама: тип ОБЯЗАН быть один из разрешённых,
    // тексты ограничены по длине, статус только 'pending',
    // поля title/body не пустые. Чтение/обновление/удаление —
    // только Cloud Function (от имени админа).
    match /notificationQueue/{id} {
      allow read: if isAdminUser();
      allow create: if
        reasonableDocSize()
        && request.resource.data.type is string
        && request.resource.data.type in ['chat', 'admin_chat', 'broadcast']
        && strOk('title', 200)
        && strOk('body', 1000)
        && strOk('clientId', 200)
        && strOk('targetClientId', 200)
        && strOk('clientName', 200)
        && (
          !('status' in request.resource.data)
          || request.resource.data.status == 'pending'
        );
      allow update, delete: if isAdminUser();
    }

    // =========================================================
    //                          CHAT
    // =========================================================
    // chatClients — список клиентов чата.
    //   READ — только залогиненные (анонимный auth подходит).
    //   UPDATE — клиент может менять name/pushToken/lastActive свои,
    //            но не подменять чужой документ. Защита по совпадению
    //            phone в resource.data — клиент не может изменить
    //            запись с другим phone, кроме своего.
    //   DELETE — только админ.
    match /chatClients/{id} {
      allow read: if isAuthed();
      allow create: if
        reasonableDocSize()
        && strOk('name', 200)
        && strOk('phone', 30)
        && strOk('pushToken', 500);
      allow update: if reasonableDocSize() && (
        isAdminUser()
        || (
          // Клиент может менять свой документ (name/pushToken/hasUnread/lastActive),
          // но не телефон.
          isAuthed()
          && fieldUnchanged('phone')
          && strOk('name', 200)
          && strOk('pushToken', 500)
        )
      );
      allow delete: if isAdminUser();
    }

    // chatMessages — сообщения чата.
    //   READ — только залогиненные.
    //   CREATE — любой залогиненный (с валидацией текста и блокировкой
    //            заблокированных клиентов).
    //   UPDATE — админ всё; клиент только отмечает «прочитано».
    //   DELETE — только админ.
    match /chatMessages/{id} {
      allow read: if isAuthed();
      allow delete: if isAdminUser();
      allow update: if reasonableDocSize() && (
        isAdminUser()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      allow create: if
        isAuthed()
        && reasonableDocSize()
        && strOk('text', 5000)
        && strOk('clientId', 200)
        && strOk('sender', 50)
        && (
          !('clientId' in request.resource.data)
          || !exists(/databases/$(database)/documents/blockedClients/$(request.resource.data.clientId))
        );
    }

    // =========================================================
    //                ВСЁ ОСТАЛЬНОЕ — НАГЛУХО
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
