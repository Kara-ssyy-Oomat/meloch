# ===================================================================
# .gitignore для проекта Кербен B2B Market
# ===================================================================

# ---------- Зависимости и сборка ----------
node_modules/
functions/node_modules/
**/node_modules/
dist/
build/

# ---------- Секреты и переменные окружения ----------
# НИКОГДА не коммитить эти файлы!
.env
.env.*
*.env
!.env.example
secrets.json
service-account*.json
*serviceAccount*.json
firebase-adminsdk-*.json
*.pem
*.key
*.p12
*.cert

# ---------- Firebase локальные файлы ----------
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.runtimeconfig.json
functions/.runtimeconfig.json

# ---------- IDE и редакторы ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Логи ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Кеши ----------
.cache/
.parcel-cache/
.eslintcache
.npm/
.yarn/

# ---------- Временные файлы ----------
*.tmp
*.temp
*.bak
*.backup
*~

# ---------- Чувствительные локальные файлы ----------
TODO.local.md
notes.local.md
config.local.js
config.local.json

# ---------- Сертификаты SSL ----------
*.crt
*.csr
ssl/

# ---------- Прочее ----------
coverage/
.nyc_output/
